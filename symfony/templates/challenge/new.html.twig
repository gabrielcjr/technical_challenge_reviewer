{% extends 'base.html.twig' %}

{% block title %}New Challenge{% endblock %}

{% block body %}
<div class="max-w-2xl mx-auto">
    <h1 class="text-2xl font-bold mb-6">Create New Challenge</h1>

    <form method="POST" action="{{ path('challenge_create_form') }}" class="bg-white p-6 rounded shadow space-y-6">
        <div>
            <label class="block text-sm font-medium text-gray-700">Title *</label>
            <input type="text" name="title" required class="mt-1 block w-full border border-gray-300 rounded px-3 py-2" placeholder="e.g. Build a TODO API">
        </div>

        <div>
            <label class="block text-sm font-medium text-gray-700">Description * (requirements sent to AI evaluator)</label>
            <textarea name="description" rows="10" required class="mt-1 block w-full border border-gray-300 rounded px-3 py-2" placeholder="Describe requirements: The API must have endpoints... Use clean architecture... Include tests..."></textarea>
            <p class="text-xs text-gray-500 mt-1">Be specific - this text is sent to LLM for evaluation.</p>
        </div>

        <div class="flex justify-between">
            <a href="{{ path('home') }}" class="px-4 py-2 border rounded text-gray-700">Cancel</a>
            <button type="submit" class="bg-gray-800 text-white px-6 py-2 rounded hover:bg-gray-700">Create Challenge</button>
        </div>
    </form>
</div>
{% endblock %}
