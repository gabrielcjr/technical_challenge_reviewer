# Postgres
POSTGRES_DB=challenge_reviewer
POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_PORT=5432

# Symfony
DATABASE_URL=postgresql://app:app@database:5432/challenge_reviewer?serverVersion=17&charset=utf8
MESSENGER_TRANSPORT_DSN=doctrine://default?queue_name=async
APP_SECRET=change_me_to_random_32_chars
APP_ENV=dev
SYMFONY_PORT=8080
SYMFONY_APP_URL=http://localhost:8080
PYTHON_EVALUATOR_URL=http://python-evaluator:8000
CALLBACK_TOKEN=s3cr3t_shared_token_change_me

# Python Evaluator
EVALUATOR_PORT=8001
GROK_API_KEY=gsk_your_grok_key_here
GEMINI_API_KEY=your_gemini_key_here
LLM_PROVIDER=auto
# auto | grok | gemini
SYMFONY_CALLBACK_URL=http://nginx/api/internal/evaluation-result
# For python calling back inside docker network, nginx resolves php
SYMFONY_INTERNAL_CALLBACK_URL=http://nginx/api/internal/evaluation-result
CALLBACK_TOKEN_SHARED=s3cr3t_shared_token_change_me

# Optional
COMPOSER_ALLOW_SUPERUSER=1
